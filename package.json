{
  "name": "riven",
  "version": "0.0.7",
  "description": "riven — AI-first IDE with fully dockable panels, own Monaco editor, integrated terminals",
  "productName": "riven",
  "main": "./out/main/index.js",
  "author": "riven",
  "scripts": {
    "dev": "electron-vite dev",
