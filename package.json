    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "bash-language-server": "^5.6.0",
    "chokidar": "^3.6.0",
    "dockview": "^7.0.2",
    "dockview-react": "^7.0.2",
    "electron-updater": "^6.8.9",
