# Supabase — enables the Account tab (Google/GitHub login + settings sync).
# Copy this file to `.env` and fill in your project's values. When these are
# absent the feature stays disabled and the rest of the app works normally.
#
# Find these in the Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Redirect target the provider bounces back to after auth. It is never actually
# loaded — the app intercepts the navigation to read the PKCE code — but it MUST
# be listed under Authentication → URL Configuration → Redirect URLs in Supabase.
VITE_SUPABASE_REDIRECT=https://localhost/riven/auth/callback
