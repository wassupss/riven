# macOS 서명 + 공증용 빌드 시크릿 (electron-builder가 process.env에서 읽음).
#
# 사용법:
#   cp .env.build.example .env.build   # .env.build 는 gitignore 됨
#   # 값 채운 뒤:
#   source .env.build && npm run dist
#
# 주의: 이건 렌더러의 .env(VITE_SUPABASE_*)와 다릅니다. 앱 번들에 들어가지
# 않고, 오직 dmg 서명/공증에만 쓰입니다. Vite 는 이 값을 읽지 않습니다.

export APPLE_ID="you@example.com"                       # Apple ID 이메일 (비밀 아님)
export APPLE_TEAM_ID="ABCDE12345"                       # Membership → Team ID, 10자리 (비밀 아님)
export APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx" # account.apple.com → 앱 암호 (★비밀★)

# --- 대안: App Store Connect API 키 방식 (위 3개 대신) ---
# export APPLE_API_KEY="/absolute/path/AuthKey_XXXX.p8"
# export APPLE_API_KEY_ID="XXXXXXXXXX"
# export APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
